# Access token of the Fordefi API user acting as the CoSigner.
# The API user must be included as an approver in the policy rule's approval quorum.
FORDEFI_API_USER_TOKEN=your_fordefi_api_user_access_token

# Address of the Fordefi vault whose transactions this CoSigner validates.
ORIGIN_VAULT=0xYourFordefiVaultAddress

# Fordefi's webhook signing public key (defaults to the one committed in this repo).
FORDEFI_PUBLIC_KEY_PATH=./public_key.pem

# Log verbosity (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
LOG_LEVEL=INFO

# Directory for the persisted audit log (rotated daily). Defaults to ./live-logs.
LOG_DIR=./live-logs

# How many days of rotated audit logs to retain. Defaults to 90.
LOG_RETENTION_DAYS=90
