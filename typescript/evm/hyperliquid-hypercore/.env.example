# Fordefi API credentials (required)
FORDEFI_API_USER_TOKEN=

# Fordefi EVM vault that acts as the Hyperliquid master account (required)
FORDEFI_EVM_VAULT_ID=
FORDEFI_EVM_VAULT_ADDRESS=

# Action to run (see src/config.ts). One of:
# deposit | withdraw | sendUsd | vault_transfer | approve_agent | revoke_agent | spotTransfer | subAccountTransfer | placeOrder
ACTION=subAccountTransfer

# Sub-account address for the "subAccountTransfer" action — used as transfer.to in src/config.ts.
# Create the sub-account in the Hyperliquid (testnet) UI first, then paste its address here.
SUBACCOUNT_ADDRESS=
