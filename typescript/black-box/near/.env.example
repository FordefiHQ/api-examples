# Fordefi API Configuration
FORDEFI_API_USER_TOKEN=your_fordefi_token_here
BLACKBOX_VAULT_ID=your_vault_id_here
VAULT_PUBLIC_KEY=... # compressed ed25519 public key (base64)


# NEAR Configuration
NEAR_ADDRESS=... # Your NEAR

# For Staking
STAKING_POOL_ID=... # The staking pool ID you want to delegate into
## https://nearblocks.io/node-explorer

# For Transfers
DESTINATION_ADDRESS=... # Recipient on NEAR chain
# Network Configuration
NEAR_NETWORK=mainnet # mainnet
PCHAIN_RPC_URL=https://1rpc.io/near

# For Intents (1Click cross-chain swaps)
# Swap parameters are configured in src/intents/swap-config.json
ONECLICK_API_KEY=                              # Optional: avoids 0.1% fee

# For Intents Solver
# Solver parameters are configured in src/intents-solver/solver-config.json
SOLVER_API_KEY=                                              # Required: Solver Relay API key (get from NEAR Intents team)
GCP_KMS_KEY_NAME=projects/YOUR_PROJECT/locations/YOUR_LOCATION/keyRings/near-solver/cryptoKeys/solver-signer/cryptoKeyVersions/1  # GCP KMS ED25519 key for quote signing
SOLVER_RELAY_URL=wss://solver-relay-v2.chaindefuser.com/ws  # Optional: overrides solver-config.json
INTENTS_CONTRACT=intents.near                                # Optional: overrides solver-config.json
