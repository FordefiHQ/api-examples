# Fordefi API Configuration
FORDEFI_API_USER_TOKEN=your_fordefi_token_here
BLACKBOX_VAULT_ID=your_vault_id_here
VAULT_PUBLIC_KEY=... # compressed ed25519 public key (base64)


# NEAR Configuration
NEAR_ADDRESS=... # Your NEAR

# For Staking
STAKING_POOL_ID=... # The staking pool ID you want to delegate into
## https://nearblocks.io/node-explorer

# For Transfers
DESTINATION_ADDRESS=... # Recipient on NEAR chain
# Network Configuration
NEAR_NETWORK=mainnet # mainnet
PCHAIN_RPC_URL=https://1rpc.io/near

# For Intents (1Click cross-chain swaps)
# Asset IDs: use 1Click assetId from /v0/tokens (e.g. "nep141:wrap.near")
#   or legacy format "chain:network:address" (e.g. "near:mainnet:native", "eth:1:native")
INTENTS_ORIGIN_ASSET=near:mainnet:native      # Native NEAR (auto-wraps to wNEAR)
INTENTS_DESTINATION_ASSET=eth:1:native         # Target asset
INTENTS_AMOUNT=1000000000000000000000000       # Amount in smallest unit (1 NEAR in yoctoNEAR)
INTENTS_RECIPIENT=0x...                        # Recipient address on destination chain
INTENTS_SLIPPAGE=100                           # Slippage tolerance in basis points (100 = 1%)
ONECLICK_API_KEY=                              # Optional: avoids 0.1% fee
