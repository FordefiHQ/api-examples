# Fordefi API Configuration
FORDEFI_API_USER_TOKEN=your_fordefi_token_here
BLACKBOX_VAULT_ID=your_vault_id_here
VAULT_PUBLIC_KEY= # 32-byte raw ed25519 public key (base64) from your Fordefi vault

# Blockfrost
BLOCKFROST_PROJECT_ID= # project id from https://blockfrost.io (must match CARDANO_NETWORK)

# For Transfers
DESTINATION_ADDRESS=addr1... # Recipient Cardano address

# For Staking
POOL_ID=pool1... # Stake pool to delegate to (bech32)

# Network Configuration
CARDANO_NETWORK=mainnet # mainnet or preprod
