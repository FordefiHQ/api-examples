# Fordefi API Configuration
FORDEFI_API_USER_TOKEN=your_fordefi_token_here
BLACKBOX_VAULT_ID=your_vault_id_here
VAULT_PUBLIC_KEY= # 32-byte raw ed25519 public key (base64) from your Fordefi vault

# For Transfers
DESTINATION_ADDRESS= # Recipient SS58 address (starts with '1' on Polkadot)

# Network Configuration
POLKADOT_NETWORK=polkadot # polkadot or westend
# POLKADOT_RPC_URL= # optional override; defaults to the network's public Asset Hub endpoint
