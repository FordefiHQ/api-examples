# Fordefi API Configuration
FORDEFI_API_USER_TOKEN=your_fordefi_token_here
BLACKBOX_VAULT_ID=your_vault_id_here
VAULT_PUBLIC_KEY= # 33-byte compressed secp256k1 public key (base64) from your Fordefi vault

# For Transfers
DESTINATION_ADDRESS=P-avax1... # Recipient P-Chain address

# For Staking
NODE_ID=NodeID-...   # Validator NodeID to delegate to
REWARD_ADDRESS=      # Optional: P-avax1... where rewards are paid (defaults to origin)

# Network Configuration
AVALANCHE_NETWORK=mainnet # mainnet or fuji
PCHAIN_RPC_URL=https://api.avax.network # or https://api.avax-test.network for fuji
