FORDEFI_API_USER_TOKEN=
FORDEFI_STELLAR_VAULT_ID=

# Plain-text message to sign. The script hex-encodes it (0x...) before sending.
# Alternatively, set STELLAR_MESSAGE_HEX with a pre-built 0x-prefixed hex string,
# which takes precedence over STELLAR_MESSAGE.
STELLAR_MESSAGE=Hello from Fordefi
# STELLAR_MESSAGE_HEX=0x48656c6c6f

# Optional dapp_info attached to the message request.
STELLAR_DAPP_NAME=Fordefi Stellar Example
STELLAR_DAPP_URL=https://example.com
