FORDEFI_API_USER_TOKEN=
FORDEFI_STELLAR_VAULT_ID=

# G... public key of the Fordefi Stellar vault — used as the source account when
# building the unsigned transaction locally. Must match FORDEFI_STELLAR_VAULT_ID.
STELLAR_VAULT_ADDRESS=

# Native XLM payment built locally and submitted as raw XDR.
STELLAR_DESTINATION=
STELLAR_AMOUNT="1.0"

# Optional Horizon override (defaults to https://horizon.stellar.org).
# STELLAR_HORIZON_URL=https://horizon.stellar.org
